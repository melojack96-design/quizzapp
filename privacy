  <title>سياسة الخصوصية</title>
  <style>
    body{font-family:Arial,sans-serif;background:#f5f7fb;color:#222;margin:0;padding:40px}
    .container{max-width:800px;margin:auto;background:#fff;padding:30px;border-radius:16px;box-shadow:0 10px 30px rgba(0,0,0,.08)}
